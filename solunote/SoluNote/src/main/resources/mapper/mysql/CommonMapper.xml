<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<mapper namespace="com.vol.solunote.mapper.comm.CommonMapper">
    
    <resultMap id="domainInfo" type="com.vol.solunote.model.vo.comm.DomainVo">
	    <result property="seq" column="seq" javaType="int" />
	    <result property="domainCode" column="tc_domain_code" javaType="java.lang.String" />
	    <result property="domainName" column="tc_domain_name" javaType="java.lang.String" />
	    <result property="domainExplain" column="tc_domain_explain" javaType="java.lang.String" />
	    <result property="userSeq" column="tc_user_seq" javaType="int" />
	    <result property="useYn" column="tc_useyn" javaType="java.lang.String" />
	    <result property="regDate" column="tc_regdate" javaType="java.lang.String" />
	</resultMap>
        
    <resultMap id="sesrverInfo" type="Map">
	    <result property="seq" column="seq" javaType="int" />
	    <result property="svrNick" column="tc_svrnick" javaType="java.lang.String" />
	    <result property="svrChannel" column="tc_svrchannel" javaType="java.lang.String" />
	    <result property="wavfileDays" column="tc_wavfile_days" javaType="java.lang.String" />
	    <result property="mp3fileDays" column="tc_mp3file_days" javaType="java.lang.String" />
        <result property="svrIp" column="tc_svrip" javaType="java.lang.String" />
	    <result property="svrPort" column="tc_svrport" javaType="java.lang.String" />
	    <result property="regDate" column="tc_regdate" javaType="java.lang.String" />
	    <result property="useYn" column="tc_useyn" javaType="int" />
	</resultMap>
        
    <select id="selectDomainList" resultMap="domainInfo">
        CALL fn_web_common_domain_info_list()
    </select>
    
    <select id="selectSchedulerDomainList" resultMap="domainInfo">
        CALL fn_web_menu14_scheduler_domain_list()
    </select>
        
    <select id="selectServerList" resultMap="sesrverInfo">
        CALL fn_web_common_server_info_list()
    </select>
        
    <select id="selectRatio" resultType="java.lang.Long">
        CALL fn_get_ref_ratio()
    </select>
    
    <select id="selectRatioConfigration" resultType="HashMap">
        CALL fn_get_ref_ratio()
    </select>
   
</mapper>
