	<logger name="org.springframework.core.log.CompositeLog" additivity="false"> 
		<level value="INFO"/> 
		<appender-ref ref="console"/> 
	</logger>
	
	
	<logger name="net.sf.log4jdbc.log.slf4j.Slf4jSpyLogDelegator" additivity="false"> 
		<level value="DEBUG"/> 
		<appender-ref ref="console"/> 
	</logger>
	
	<logger name="org.apache.ibatis.logging.jdbc.BaseJdbcLogger" additivity="false"> 
		<level value="DEBUG"/> 
		<appender-ref ref="console"/> 
	</logger>
	
	<logger name="com.sgsas" additivity="false"> 
		<level value="DEBUG"/> 
		<appender-ref ref="console"/> 
	</logger>
	
	<root level="error" additivity="true" >
		<appender-ref ref="console" />
		<appender-ref ref="logfile" />
	</root>
</configuration>