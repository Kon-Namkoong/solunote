	<logger name="jdbc.sqlonly" additivity="false"> 
		<level value="TRACE"/> 
		<appender-ref ref="console"/> 
	</logger>
     
	<logger name="jdbc.resultsettable" additivity="false"> 
		<level value="TRACE"/>  
		<appender-ref ref="console"/> 
	</logger> 
     
	<logger name="org.springframework.transaction" additivity="false"> 
		<level value="TRACE"/>  
		<appender-ref ref="console"/> 
	</logger> 
	
	<!--  HikariCP connection pool leak debug https://do-study.tistory.com/97 -->
	<logger name="com.zaxxer.hikari.HikariConfig" additivity="false"> 
		<level value="DEBUG"/>  
		<appender-ref ref="console"/> 
	</logger> 
	
	<logger name="com.zaxxer.hikari" additivity="false"> 
		<level value="TRACE"/>  
		<appender-ref ref="console"/> 
	</logger> 
	
